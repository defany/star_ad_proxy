{
  // "dev" → http for derived URLs in clients; anything else → https
  "env": "dev",
  "http": {
    "addr": ":8080"
  },
  "dragonfly": {
    "addr": "localhost:6379",
    "password": "",
    // separate Dragonfly logical DB to keep proxy keys isolated
    "db": 0
  },
  "admin": {
    // shared secret for POST/GET/DELETE /register — Bearer token
    "token": "change-me"
  },
  "forwarder": {
    // per-request HTTP timeout when forwarding a sub-batch to a target
    "timeout": "8s"
  }
}
