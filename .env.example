CONFIG_PATH=config/local.json

ADMIN_TOKEN=replace-me

DRAGONFLY_ADDR=localhost:6379
# Empty in dev (Dragonfly runs without --requirepass).
# In prod: set this; docker-compose.prod.yaml passes it to BOTH the
# Dragonfly server (--requirepass) and the app client (DRAGONFLY_PASSWORD).
DRAGONFLY_PASSWORD=
DRAGONFLY_DB=0

HTTP_ADDR=:8080

FORWARDER_TIMEOUT=8s
